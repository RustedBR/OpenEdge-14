<BoxContainer xmlns="https://spacestation14.io"
              xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
              Orientation="Vertical"
              Margin="5 5 5 5">
    <PanelContainer HorizontalExpand="True">
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxFlat BorderThickness="1" BorderColor="#777777"/>
        </PanelContainer.PanelOverride>
        <BoxContainer Orientation="Vertical">
            <PanelContainer HorizontalExpand="True" VerticalExpand="False">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#5c3a1e"/>
                </PanelContainer.PanelOverride>
                <RichTextLabel Name="RecipeName" HorizontalAlignment="Center"/>
            </PanelContainer>
            <BoxContainer Name="IconsContainer" Orientation="Horizontal"
                          HorizontalAlignment="Center" Margin="3 3 3 0"/>
            <BoxContainer Name="RequirementsContainer" HorizontalExpand="True">
                <Collapsible HorizontalExpand="True">
                    <CollapsibleHeading Title="{Loc 'oe14-guidebook-cooking-requirements-header'}"/>
                    <CollapsibleBody>
                        <BoxContainer Orientation="Vertical" Margin="10 0 10 0">
                            <RichTextLabel Name="RequirementsLabel"/>
                        </BoxContainer>
                    </CollapsibleBody>
                </Collapsible>
            </BoxContainer>
            <BoxContainer Margin="10 5 10 10" HorizontalExpand="True">
                <RichTextLabel Name="RecipeDescription" HorizontalAlignment="Left"/>
            </BoxContainer>
        </BoxContainer>
    </PanelContainer>
</BoxContainer>
