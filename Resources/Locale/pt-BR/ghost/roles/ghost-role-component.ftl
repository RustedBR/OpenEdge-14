ghost-role-information-Death-Squad-rules = Você é obrigado a obedecer ordens dadas pelo seu superior, você é efetivamente o [color={role-type-familiar-color}][bold]{role-type-familiar-name}[/bold][/color] dele.

ghost-role-information-SyndiCat-name = SyndiCat
ghost-role-information-SyndiCat-description = Você é o pet treinado fiel dos operadores nucleares com uma microbomba. Sirva seu mestre até a morte!
ghost-role-information-SyndiCat-rules = Você é um [color={role-type-team-antagonist-color}][bold]{role-type-team-antagonist-name}[/bold][/color] com o agente que te invocou.

ghost-role-information-Cak-name = Cak
