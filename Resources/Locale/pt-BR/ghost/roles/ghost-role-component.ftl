ghost-role-information-behonker-name = Behonker
ghost-role-information-behonker-description = Você é um antagonista, traga morte e honks para aqueles que não seguem a honkmãe.

ghost-role-information-hellspawn-name = Hellspawn
ghost-role-information-hellspawn-description = Traga morte para aqueles que não seguem o grande deus Nar'Sie.

