# OE14 Entity Names - Materials

ent-OE14ThinLeather1 = couro fino
    .desc = Couro fino de animal não tratado. Parece que você pode afundá-lo com o dedo!

ent-OE14Leather1 = couro grosso
    .desc = Couro de animal não tratado. Daria uma ótima bolsa.

ent-OE14RuggedLeather1 = couro resistente
    .desc = Couro de animal durável. Daria ótimas botas caras ou até protegeria contra cortes.

ent-OE14ScrapLeather = retalhos de couro
    .desc = Retalhos de pele, alguém cortou isso sem cuidado!

ent-OE14ScrapCopper = sucata de cobre
    .desc = Pedaços tortos de cobre. Inúteis. Só servem para serem derretidos.

ent-OE14ScrapIron = sucata de ferro
    .desc = Pedaços tortos de ferro. Inúteis. Só servem para serem derretidos.

ent-OE14ScrapGold = sucata de ouro
    .desc = Pedaços tortos de ouro. Inúteis. Só servem para serem derretidos.

ent-OE14ScrapMithril = sucata de mithril
    .desc = Pedaços tortos de mithril. Inúteis. Só servem para serem derretidos.

ent-OE14IronBuckle = fivela de ferro
    .desc = Uma fivela de metal resistente para prender tiras e cintos.

ent-OE14BloodEssence = essência de sangue
    .desc = A essência da vida, extraída à força. Apenas verdadeiros vampiros sabem como usá-la.

ent-OE14FloraMaterial1 = material de flora
    .desc = Um material orgânico usado para fins medicinais ou de construção.

ent-OE14CompostMaterial1 = composto
    .desc = Já foi uma planta bonita e vibrante, ou comida. Agora é uma pilha fedorenta de matéria orgânica em decomposição.

ent-OE14Ash1 = cinzas # possível reagente no futuro
