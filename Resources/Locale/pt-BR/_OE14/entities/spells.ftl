# OE14 Entity Names - Spells

ent-OE14BaseSpellScroll = pergaminho de feitiço
    .desc = Um pedaço de papel com um feitiço embutido. O uso da magia destrói o papel frágil, tornando esses pergaminhos consumíveis de curta duração.

ent-OE14BaseMagicRune = runa mágica
    .desc = manifestação de energia mágica no plano físico

ent-OE14BaseMagicImpact = impacto mágico
    .desc = manifestação de energia mágica no plano físico

ent-OE14BaseMagicTrap = armadilha mágica
    .desc = Manifestação de energia mágica no plano físico

ent-OE14ActionSpellIceDagger = Adaga de gelo
    .desc = Você forma uma adaga afiada de gelo para uso temporário.

ent-OE14WeaponDaggerIce = adaga de gelo
