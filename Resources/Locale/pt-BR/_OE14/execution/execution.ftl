# All the below localisation strings have access to the following variables
# attacker (the person committing the execution)
# victim (the person being executed)
# weapon (the weapon used for the execution)

oe14-execution-popup-melee-initial-internal = Você prepara {THE($weapon)} para executar {THE($victim)}.
oe14-execution-popup-melee-initial-external = { CAPITALIZE(THE($attacker)) } prepara {POSS-ADJ($attacker)} {$weapon} para executar {THE($victim)}.
oe14-execution-popup-melee-complete-internal = Você executou {THE($victim)}!
oe14-execution-popup-melee-complete-external = { CAPITALIZE(THE($attacker)) } executou {THE($victim)}!

oe14-execution-popup-self-initial-internal = Você prepara {THE($weapon)} contra sua própria cabeça.
oe14-execution-popup-self-initial-external = { CAPITALIZE(THE($attacker)) } prepara {POSS-ADJ($attacker)} {$weapon} contra sua própria cabeça.
oe14-execution-popup-self-complete-internal = Você se matou!
oe14-execution-popup-self-complete-external = { CAPITALIZE(THE($attacker)) } se matou!