oe14-reagent-effect-guidebook-temp-affect =
    { $chance ->
        [1] Altera
        *[other] altera
    } a temperatura da solução por {$temperature} graus 

oe14-reagent-effect-guidebook-inverse-effect =
    { $chance ->
        [1] Inverte
        *[other] para inverter
    } o efeito da solução

oe14-reagent-effect-guidebook-mana-add =
    { $chance ->
        [1] Restaura {$amount} mana
        *[other] para restaurar {$amount} mana
    }

oe14-reagent-effect-guidebook-mana-remove =
    { $chance ->
        [1] Queima {$amount} mana
        *[other] para queimar {$amount} mana
    }

