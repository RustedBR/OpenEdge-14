cmd-announce-desc = Envia um anúncio no jogo com cor e som customizados.
cmd-announce-help = {$command} <mensagem> [remetente] [cor] [som] - Envia anúncio. Remetente padrão é CentCom, cor padrão é Gold, som padrão é announce.ogg. A cor deve ser em formato #RRGGBB.

# The default sender for the announcement
cmd-announce-sender = Comando Central

# Completion hints
cmd-announce-arg-message = <mensagem>
cmd-announce-arg-sender = [remetente]
cmd-announce-arg-color = [cor]
cmd-announce-arg-sound = [som]
