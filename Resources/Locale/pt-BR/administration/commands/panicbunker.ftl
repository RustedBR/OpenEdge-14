cmd-panicbunker-desc = Alterna o panic bunker, que habilita restrições mais rigorosas sobre quem tem permissão para entrar no servidor.
cmd-panicbunker-help = Uso: panicbunker
panicbunker-command-enabled = O panic bunker foi ativado.
panicbunker-command-disabled = O panic bunker foi desativado.

cmd-panicbunker_disable_with_admins-desc = Alterna se o panic bunker será desativado quando um admin conecta.
cmd-panicbunker_disable_with_admins-help = Uso: panicbunker_disable_with_admins
panicbunker-command-disable-with-admins-enabled = O panic bunker será automaticamente desativado com admins online.
panicbunker-command-disable-with-admins-disabled = O panic bunker não será automaticamente desativado com admins online.

cmd-panicbunker_enable_without_admins-desc = Alterna se o panic bunker será ativado quando o último admin desconecta.
cmd-panicbunker_enable_without_admins-help = Uso: panicbunker_enable_without_admins
panicbunker-command-enable-without-admins-enabled = O panic bunker será automaticamente ativado sem admins online.
panicbunker-command-enable-without-admins-disabled = O panic bunker não será automaticamente ativado sem admins online.

cmd-panicbunker_count_deadminned_admins-desc = Alterna se admins deadminned serão contados ao ativar e desativar automaticamente o panic bunker.
cmd-panicbunker_count_deadminned_admins-help = Uso: panicbunker_count_deadminned_admins
panicbunker-command-count-deadminned-admins-enabled = O panic bunker contou admins deadminned ao ativar e desativar automaticamente.
panicbunker-command-count-deadminned-admins-disabled = O panic bunker não contou admins deadminned ao ativar e desativar automaticamente.

cmd-panicbunker_show_reason-desc = Alterna se mostra aos clientes conectando o motivo pelo qual o panic bunker os bloqueou de entrar.
cmd-panicbunker_show_reason-help = Uso: panicbunker_show_reason
panicbunker-command-show-reason-enabled = O panic bunker agora mostrará um motivo aos usuários que bloquear de conectar.
panicbunker-command-show-reason-disabled = O panic bunker não mostrará mais um motivo aos usuários que bloquear de conectar.

cmd-panicbunker_min_account_age-desc = Obtém ou define a idade mínima da conta em minutos que uma conta deve ter para ter permissão de conectar com o panic bunker ativado.
cmd-panicbunker_min_account_age-help = Usage: panicbunker_min_account_age <minutes>
panicbunker-command-min-account-age-is = A idade mínima da conta para o panic bunker é {$minutes} minutos.
panicbunker-command-min-account-age-set = Definida a idade mínima da conta para o panic bunker para {$minutes} minutos.

cmd-panicbunker_min_overall_minutes-desc = Obtém ou define o tempo de jogo mínimo total em minutos que uma conta deve ter para ter permissão de conectar com o panic bunker ativado.
cmd-panicbunker_min_overall_minutes-help = Usage: panicbunker_min_overall_minutes <minutes>
panicbunker-command-min-overall-minutes-is = O tempo de jogo mínimo total para o panic bunker é {$minutes} minutos.
panicbunker-command-min-overall-minutes-set = Definido o tempo de jogo mínimo total para o panic bunker para {$minutes} minutos.
